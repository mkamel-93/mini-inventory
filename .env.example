# Start Docker Configuration

# End Docker Configuration

# ----------------------------------------------------------------------------------
# Application Configuration
# ----------------------------------------------------------------------------------
APP_NAME=task-izam
APP_DEBUG=true
APP_ENV=local
APP_KEY=
APP_URL=http://${DOCKER_WEB_IP}

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

DEBUGBAR_ENABLED=false

# ----------------------------------------------------------------------------------
# Logging & Debugging
# ----------------------------------------------------------------------------------
LOG_STACK=single,rollbar

ROLLBAR_ENABLED=false
ROLLBAR_TOKEN=

OH_DEAR_HEALTH_CHECK_SECRET=

# ----------------------------------------------------------------------------------
# Database Configuration
# ----------------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=database
DB_PORT=3306
DB_DATABASE=${APP_NAME}
DB_USERNAME=root
DB_PASSWORD=P@ssw0rd

# ----------------------------------------------------------------------------------
# Services: Session, Queue, FileSystem, Broadcast and Cache
# ----------------------------------------------------------------------------------
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_COOKIE="${APP_ENV}_${APP_NAME}"
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

QUEUE_CONNECTION=sync
FILESYSTEM_DISK=public
BROADCAST_CONNECTION=log

CACHE_STORE=file

# ----------------------------------------------------------------------------------
# Redis Configuration
# ----------------------------------------------------------------------------------
REDIS_PREFIX="${APP_ENV}-"
# REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=P@ssw0rd
REDIS_PORT=6379
REDIS_DB=1
REDIS_CACHE_DB=2

# ----------------------------------------------------------------------------------
# Mail Configuration
# ----------------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="mostafakamel000@gmail.com"
MAIL_FROM_NAME="${APP_NAME}"

# -------------------------------------------------------------------------
# External Services & APIs (AWS, etc.)
# -------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ----------------------------------------------------------------------------------
# Frontend & Assets (Vite)
# ----------------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
VITE_APP_ENV="${APP_ENV}"
VITE_APP_URL="${APP_URL}"

# ----------------------------------------------------------------------------------
# Miscellaneous Security & Performance
# ----------------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS="http://${DOCKER_WEB_IP}"
APP_CACHE_RESULTS_ENABLED=false
APP_CACHE_RESULTS_TTL=60
